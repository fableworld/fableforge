{
  "productName": "FableForge",
  "version": "0.3.1",
  "identifier": "dev.d71.fableforge",
  "mainBinaryName": "FableForge",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FableForge",
        "width": 1024,
        "height": 700,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**/*"
        ]
      },
      "csp": "default-src 'self'; img-src 'self' asset: https: data: http://asset.localhost; media-src 'self' asset: http://asset.localhost blob:; connect-src 'self' asset: https:;"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["fableforge"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "entitlements": null,
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}